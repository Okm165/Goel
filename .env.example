# Derive HFT Bot Configuration

# API Endpoints
DERIVE_WS_URL=wss://api.lyra.finance/ws
DERIVE_REST_URL=https://api.lyra.finance

# Execution Mode (false = observation only)
ENABLE_EXECUTOR=false

# Credentials (required only when ENABLE_EXECUTOR=true)
# SESSION_KEY_PRIVATE=0x...
# SUBACCOUNT_ID=12345

# Trading Parameters
MIN_PROFIT_USD=1.00
MAX_QUOTE_AGE_MS=1000
MIN_TRADE_SIZE=0.1
RISK_FREE_RATE=0.05

# Assets to Monitor
UNDERLYINGS=ETH,BTC

# Logging
LOG_LEVEL=INFO
OUTPUT_CSV=opportunities.csv
